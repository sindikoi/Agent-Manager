# Copy this file to ".env" (in the same folder) and fill in your real values.
# .env is already in .gitignore and must NEVER be committed to git.

# MongoDB Atlas connection string.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/people?retryWrites=true&w=majority
