# Copy this file to ".env" (in the same folder) and fill in your real values.
# .env is already in .gitignore and must NEVER be committed to git.

# MongoDB Atlas connection string.
# The app always uses the database named "safeshift" (collections: organizations,
# employees, result, announcements), regardless of the path in this URI.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Port for the Express server (optional, defaults to 3002)
PORT=3002

# Anthropic API key — powers the AI agent chat. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Python executable used to run the OR-Tools scheduler (default "python").
# Windows: full path, e.g. C:\Users\<you>\AppData\Local\Programs\Python\Python313\python.exe
# Docker/Render: /opt/venv/bin/python  (set automatically by the Dockerfile)
PYTHON_BIN=python
